{
  "name": "swapy-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --recursive --parallel dev",
    "dev:backend": "pnpm --filter swapy-campus-api dev",
    "dev:frontend": "pnpm --filter swapy-campus-frontend dev",
    "build": "pnpm --recursive build",
    "build:backend": "pnpm --filter swapy-campus-api build",
    "build:frontend": "pnpm --filter swapy-campus-frontend build",
    "test": "pnpm --recursive test",
    "test:backend": "pnpm --filter swapy-campus-api test",
    "prisma:generate": "pnpm --filter swapy-campus-api prisma:generate",
    "prisma:migrate": "pnpm --filter swapy-campus-api prisma:migrate",
    "prisma:studio": "pnpm --filter swapy-campus-api prisma:studio"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
